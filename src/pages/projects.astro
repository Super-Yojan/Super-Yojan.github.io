---
// src/pages/projects.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: "Autonomous Blimp — 152–0",
    id: "PRJ-001",
    status: "Completed",
    tags: ["Computer Vision", "Control Systems", "ROS", "C++"],
    desc: "Wrote the full autonomous stack for a competition blimp: ball detection, tracking, and capture. Won by the largest recorded margin (152–0). Then rebuilt the platform to be cheaper and more compact without losing performance.",
    link: "#"
  },
  {
    title: "Databuoy — Full Stack Sensor Infrastructure",
    id: "PRJ-002",
    status: "Completed",
    tags: ["U-Boot", "FPGA", "Embedded C", "Linux"],
    desc: "Owned U-Boot and boot sequences for deployed gunshot-detection sensors. Built automated hardware testing, a full-stack web relay (UI + backend + relay firmware), FPGA autocorrelation algorithm, Linux image maintenance, and a drone sound detection pipeline with live visualization and labeling tools.",
    link: "#"
  },
  {
    title: "CTF Platform — 500+ Teams, Age 17",
    id: "PRJ-003",
    status: "Completed",
    tags: ["Security", "FPGA", "Web", "Hardware"],
    desc: "Built a CTF platform from scratch in high school and hosted a county-wide and international competition. Later created FPGA and hardware challenges for Patriot CTF and competed in MACCDC (Cyber Defense Competition). Won Cyber Fusion CTF.",
    link: "#"
  },
  {
    title: "Blimp Kit — Designed, Built, Sold",
    id: "PRJ-004",
    status: "Completed",
    tags: ["PCB Design", "CAD", "iOS", "Education"],
    desc: "Designed the PCB, all 3D printed components, and a companion app for a complete blimp kit. Sold 20 units to middle schoolers and organized a competition around them. End-to-end product ownership: hardware, firmware, mobile.",
    link: "#"
  },
  {
    title: "Raytheon Drone — Water-Pouring Interceptor",
    id: "PRJ-005",
    status: "Completed",
    tags: ["Drones", "Computer Vision", "Team Lead", "ROS"],
    desc: "Led a team to build an autonomous drone that detected an opponent ground vehicle and poured water on it. Team lead across hardware, autonomy, and mission planning.",
    link: "#"
  },
  {
    title: "CIAO Lab — Multi-Agent Autonomous Systems (PhD)",
    id: "PRJ-006",
    status: "Active",
    tags: ["Control Theory", "Reinforcement Learning", "Python", "Rust"],
    desc: "Research at GMU covering blimp pitch control, optical flow navigation, OptiTrack/IMU pipelines, differential thrust vectoring, and heterogeneous multi-agent coordination across aerial, ground, and underwater platforms.",
    link: "#"
  },
  {
    title: "Patriot Hacks — Sustainability Award, 3rd Place",
    id: "PRJ-007",
    status: "Completed",
    tags: ["Computer Vision", "Reinforcement Learning", "Sustainability", "Hackathon"],
    desc: "Before LLMs made generative AI mainstream, built an app that used computer vision and a multi-model RL pipeline to scan household objects and generate step-by-step DIY build guides. Added a social layer so neighbors could share parts they'd otherwise discard — making one person's trash another's raw material.",
    link: "#"
  }
];
---

<BaseLayout title="Engineering Logs">
    <div class="archive-container">
        
        <header class="page-header">
            <h1>Engineering <span class="highlight">Logs</span></h1>
            <p class="subtitle">Hardware / Robotics / Systems / Security / Product</p>
        </header>

        <div class="grid">
            {projects.map((project, index) => (
                <a href={project.link} class="card fade-in" style={`animation-delay: ${index * 0.1}s`}>
                    <div class="card-header">
                        <span class="project-id">{project.id}</span>
                        <span class={`status-badge ${project.status.toLowerCase()}`}>{project.status}</span>
                    </div>
                    
                    <h3>{project.title}</h3>
                    <p>{project.desc}</p>
                    
                    <div class="tags">
                        {project.tags.map(tag => (
                            <span class="tag">#{tag}</span>
                        ))}
                    </div>
                    
                    <div class="card-footer">
                        <span class="link-arrow">ACCESS_REPO -></span>
                    </div>
                </a>
            ))}
        </div>

    </div>
</BaseLayout>

<style>
    .archive-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .page-header {
        margin-bottom: 4rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 2rem;
    }

    h1 {
        font-size: 3rem;
        font-weight: 300;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: -1px;
    }

    .highlight {
        font-weight: 700;
        color: var(--accent);
    }

    .subtitle {
        font-family: var(--font-code);
        color: var(--text);
        opacity: 0.6;
        margin-top: 0.5rem;
    }

    /* GRID LAYOUT */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }

    /* CARD STYLES */
    .card {
        display: flex;
        flex-direction: column;
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--border);
        padding: 1.5rem;
        text-decoration: none;
        color: var(--text);
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

    .card:hover {
        background: var(--mono-bg);
        border-color: var(--accent);
        transform: translateY(-2px);
    }

    /* Card Header */
    .card-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        font-family: var(--font-code);
        font-size: 0.75rem;
    }

    .project-id { opacity: 0.5; }

    .status-badge {
        padding: 2px 6px;
        border: 1px solid var(--border);
        border-radius: 4px;
        text-transform: uppercase;
        font-size: 0.65rem;
    }
    .status-badge.active { color: #00ff41; border-color: #00ff41; }
    .status-badge.beta { color: #ffcc00; border-color: #ffcc00; }
    .status-badge.completed { color: var(--accent); border-color: var(--accent); }

    h3 {
        font-size: 1.25rem;
        margin: 0 0 0.5rem 0;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    p {
        font-size: 0.9rem;
        opacity: 0.8;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        flex-grow: 1; /* Pushes footer down */
    }

    /* Tags */
    .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .tag {
        font-family: var(--font-code);
        font-size: 0.75rem;
        color: var(--accent);
        opacity: 0.8;
    }

    /* Footer */
    .card-footer {
        font-family: var(--font-code);
        font-size: 0.8rem;
        text-align: right;
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.2s;
    }
    .card:hover .card-footer { opacity: 1; transform: translateX(0); }
    .link-arrow { color: var(--accent); }

    /* Animations */
    .fade-in {
        opacity: 0;
        animation: fadeIn 0.5s ease forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
