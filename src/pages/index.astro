---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
    <main class="hero-terminal">
        <div class="left">
            <div class="hero-kicker fade-in">
                <span class="dot"></span>
                <span>SYSTEM ONLINE</span>
                <span style="opacity:0.4">//</span>
                <span>PHD RESEARCHER · GMU CIAO LAB</span>
            </div>

            <h1 class="hero-display fade-in delay-1">
                Systems<br />
                <span class="stroked">Builder.</span><br />
                All the way <span class="accent">down.</span>
            </h1>

            <p class="hero-sub fade-in delay-2">
                I build things from the bare metal up — analog circuits to
                consumer apps. PhD researcher in autonomous systems at GMU.
                Founder of Glid.
            </p>

            <div class="hero-stats fade-in delay-3">
                <div class="hero-stat">
                    <div class="v">152<small>– 0</small></div>
                    <div class="l">Blimp comp · sweep</div>
                </div>
                <div class="hero-stat">
                    <div class="v">500<small>+ teams</small></div>
                    <div class="l">CTF hosted, age 17</div>
                </div>
                <div class="hero-stat">
                    <div class="v">τ<small>≈ 0.227s</small></div>
                    <div class="l">Modeled BLDC rise</div>
                </div>
            </div>

            <div class="hero-ctas fade-in delay-4">
                <a href="/projects" class="btn primary">View Projects</a>
                <a href="/blog" class="btn secondary">Engineering Logs</a>
                <a href="/about" class="btn secondary">About / CV</a>
            </div>
        </div>

        <div class="right fade-in delay-2">
            <div class="live-term">
                <div class="bar">
                    <div class="lights">
                        <span class="r"></span><span class="y"></span><span
                            class="g"></span>
                    </div>
                    <div>yojan@gmu — zsh — 86×24</div>
                </div>
                <div class="body" id="term-body" aria-live="polite"></div>
            </div>
        </div>
    </main>

    <script is:inline>
        (function () {
            var lines = [
                {
                    kind: "cmd",
                    dir: "~/glid",
                    branch: "(main)",
                    text: "cargo run --release",
                },
                { kind: "out", text: "   Compiling glid-core v0.4.1" },
                { kind: "out", text: "   Compiling glid-routing v0.4.1" },
                {
                    kind: "out",
                    text: "    Finished release [optimized] target(s) in 4.21s",
                },
                {
                    kind: "ok",
                    text: "✓ Beta build OK · 318 KB · DMV region",
                },
                {
                    kind: "cmd",
                    dir: "~/blimp",
                    branch: "(autonomy)",
                    text: "rosrun blimp_autonomy estimator",
                },
                {
                    kind: "out",
                    text: "[INFO] Kalman filter initialized · 6-state · σ=0.10",
                },
                { kind: "info", text: "[INFO] EKF lock acquired in 11 ms" },
                {
                    kind: "out",
                    text: "[INFO] Position drift: 0.4 cm/s · within tolerance",
                },
                {
                    kind: "cmd",
                    dir: "~/papers",
                    branch: "(draft)",
                    text: "pandoc multi-agent-coord.md -o paper.pdf",
                },
                {
                    kind: "warn",
                    text: "! 2 figures missing captions — flagged for review",
                },
                {
                    kind: "cmd",
                    dir: "~/yt",
                    branch: "(main)",
                    text: "youtube-upload --schedule 2026-05-04",
                },
                {
                    kind: "ok",
                    text: '✓ Queued: "Modeling BLDC rise time in Rust" (12 min)',
                },
                {
                    kind: "cmd",
                    dir: "~",
                    branch: "(main)",
                    text: "whoami",
                },
                {
                    kind: "info",
                    text: "yojan@gmu — systems builder · all the way down",
                },
            ];

            var body = document.getElementById("term-body");
            if (!body) return;
            var i = 0;

            function escape(s) {
                return s.replace(
                    /[&<>]/g,
                    (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" })[c],
                );
            }

            function renderCmd(ln) {
                return (
                    '<div class="ln"><span class="pr">➜</span>' +
                    '<span class="dir">' +
                    escape(ln.dir) +
                    "</span>" +
                    '<span class="br">' +
                    escape(ln.branch) +
                    "</span>" +
                    "<span>" +
                    escape(ln.text) +
                    "</span></div>"
                );
            }
            function renderOut(ln) {
                var cls =
                    ln.kind === "ok"
                        ? "out ok"
                        : ln.kind === "warn"
                          ? "out warn"
                          : ln.kind === "info"
                            ? "out info"
                            : "out";
                return (
                    '<div class="' + cls + '">' + escape(ln.text) + "</div>"
                );
            }

            function tick() {
                if (i >= lines.length) {
                    body.insertAdjacentHTML(
                        "beforeend",
                        '<div class="ln"><span class="pr">➜</span>' +
                            '<span class="dir">~</span>' +
                            '<span class="br">(main)</span>' +
                            '<span class="cur"></span></div>',
                    );
                    return;
                }
                var ln = lines[i++];
                body.insertAdjacentHTML(
                    "beforeend",
                    ln.kind === "cmd" ? renderCmd(ln) : renderOut(ln),
                );
                setTimeout(tick, i < 5 ? 380 : 600);
            }
            setTimeout(tick, 400);
        })();
    </script>
</BaseLayout>
