---
import "../styles/global.css";
import { SITE_TITLE } from "../consts";
const { title, description } = Astro.props as {
    title?: string;
    description?: string;
};
const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const desc =
    description ??
    "Systems builder. PhD researcher in autonomous systems at GMU. Founder of Glid.";

const path = Astro.url.pathname;
const isActive = (href: string) =>
    href === "/"
        ? path === "/" || path === ""
        : path === href || path.startsWith(href + "/");
---

<!doctype html>
<html
    lang="en"
    data-theme="light"
    data-density="default"
    data-accent="blue"
    data-motif="dots"
>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link
            rel="preload"
            href="/fonts/atkinson-regular.woff"
            as="font"
            type="font/woff"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/atkinson-bold.woff"
            as="font"
            type="font/woff"
            crossorigin
        />
        <title>{fullTitle}</title>
        <meta name="description" content={desc} />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={desc} />
        <meta property="og:type" content="website" />
        <script is:inline>
            // Apply persisted theme before paint to avoid flicker.
            (function () {
                try {
                    var t = localStorage.getItem("theme");
                    if (t === "dark" || t === "light") {
                        document.documentElement.dataset.theme = t;
                    }
                } catch (_) {}
            })();
        </script>
    </head>
    <body>
        <div class="blueprint-grid"></div>
        <div class="vignette"></div>

        <nav class="top-nav">
            <a href="/" class="nav-logo">SYSTEM_ROOT</a>
            <div class="nav-links">
                <a href="/" class={isActive("/") ? "active" : ""}>HOME</a>
                <a
                    href="/projects"
                    class={isActive("/projects") ? "active" : ""}>PROJECTS</a
                >
                <a href="/now" class={isActive("/now") ? "active" : ""}>NOW</a>
                <a href="/blog" class={isActive("/blog") ? "active" : ""}
                    >BLOG</a
                >
                <a href="/about" class={isActive("/about") ? "active" : ""}
                    >ABOUT</a
                >
            </div>
            <button
                id="theme-toggle"
                class="theme-btn"
                aria-label="Toggle theme"><span id="theme-glyph">☾</span></button
            >
        </nav>

        <slot />

        <footer class="foot">
            <div class="sig">
                <div class="glyph">
                    <svg viewBox="0 0 100 100" aria-hidden="true">
                        <polygon
                            points="50,6 92,28 92,72 50,94 8,72 8,28"
                            stroke-width="1.5"></polygon>
                        <path
                            d="M30 38 L50 50 L70 38 M50 50 L50 78 M30 60 L70 60"
                            stroke-width="1.2"></path>
                        <circle cx="50" cy="50" r="3" fill="currentColor"
                        ></circle>
                    </svg>
                </div>
                <p>
                    Yojan Gautam — systems builder, PhD researcher, founder.
                </p>
                <div>© 2026 / Built in Astro / Hosted on github.io</div>
            </div>
            <div>
                <h5>SITE</h5>
                <a href="/">Home</a>
                <a href="/projects">Projects</a>
                <a href="/now">Now</a>
                <a href="/blog">Blog</a>
                <a href="/about">About</a>
            </div>
            <div>
                <h5>ELSEWHERE</h5>
                <a href="https://github.com/Super-Yojan" target="_blank"
                    >github.com/Super-Yojan</a
                >
                <a href="https://linkedin.com/in/yojangautam" target="_blank"
                    >linkedin.com/in/yojangautam</a
                >
                <a href="https://youtube.com/@Super-Yojan" target="_blank"
                    >youtube.com/@Super-Yojan</a
                >
            </div>
            <div>
                <h5>CONTACT</h5>
                <a href="mailto:hi@super-yojan.dev">hi@super-yojan.dev</a>
                <a href="/blog">Engineering logs →</a>
                <div class="accept">● ACCEPTING COLLAB</div>
            </div>
        </footer>

        <script is:inline>
            (function () {
                var btn = document.getElementById("theme-toggle");
                var glyph = document.getElementById("theme-glyph");
                if (!btn || !glyph) return;
                function sync() {
                    var t =
                        document.documentElement.dataset.theme === "dark"
                            ? "dark"
                            : "light";
                    glyph.textContent = t === "light" ? "☾" : "☀";
                }
                sync();
                btn.addEventListener("click", function () {
                    var cur = document.documentElement.dataset.theme;
                    var next = cur === "dark" ? "light" : "dark";
                    document.documentElement.dataset.theme = next;
                    try {
                        localStorage.setItem("theme", next);
                    } catch (_) {}
                    sync();
                });
            })();
        </script>
    </body>
</html>
