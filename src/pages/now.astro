---
import BaseLayout from "../layouts/BaseLayout.astro";

function spark(seed: number, trend: "up" | "down" | "flat") {
    const W = 280,
        H = 60,
        N = 32;
    const rng = (i: number) => {
        const x = Math.sin(seed * 9.23 + i * 1.61) * 10000;
        return x - Math.floor(x);
    };
    const pts = Array.from({ length: N }, (_, i) => {
        const base =
            trend === "up"
                ? 10 + (i / N) * 30
                : trend === "down"
                  ? 50 - (i / N) * 30
                  : 30;
        return {
            x: (i / (N - 1)) * W,
            y: H - (base + rng(i) * 16 - 8),
        };
    });
    const path = pts
        .map(
            (p, i) =>
                `${i === 0 ? "M" : "L"}${p.x.toFixed(1)} ${p.y.toFixed(1)}`,
        )
        .join(" ");
    const fill = `${path} L${W} ${H} L0 ${H} Z`;
    return { path, fill, W, H };
}

const sparks = {
    phd: spark(3, "up"),
    glid: spark(7, "up"),
    yt: spark(11, "up"),
    commits: spark(17, "flat"),
};

// 26 weeks × 7 days commit heatmap (deterministic).
const heat = Array.from({ length: 26 }, (_, w) =>
    Array.from({ length: 7 }, (_, d) => {
        const r = Math.abs(Math.sin(w * 13.7 + d * 5.3));
        return r > 0.85
            ? "l4"
            : r > 0.65
              ? "l3"
              : r > 0.4
                ? "l2"
                : r > 0.15
                  ? "l1"
                  : "";
    }),
);

const builds = [
    {
        name: "Super-Yojan/glid-core @ main",
        status: "passing",
        duration: "2m 14s",
    },
    {
        name: "Super-Yojan/glid-routing @ feat/EKF",
        status: "passing",
        duration: "3m 02s",
    },
    {
        name: "Super-Yojan/blimp-autonomy @ main",
        status: "passing",
        duration: "1m 48s",
    },
    {
        name: "Super-Yojan/bldc-rs @ main",
        status: "passing",
        duration: "0m 41s",
    },
    {
        name: "Super-Yojan/super-yojan.github.io",
        status: "passing",
        duration: "0m 26s",
    },
    { name: "Super-Yojan/papers @ draft", status: "warn", duration: "—" },
];
const buildMap: Record<string, { c: string; l: string }> = {
    passing: { c: "var(--color-term-status)", l: "PASS" },
    warn: { c: "var(--color-term-yellow)", l: "WARN" },
    fail: { c: "var(--color-term-red)", l: "FAIL" },
};
