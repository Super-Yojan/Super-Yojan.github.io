---
import BaseLayout from "../layouts/BaseLayout.astro";

type Vis = "blimp" | "glid" | "ctf" | "motor" | "yt" | "fpga";
type Project = {
    id: string;
    title: string;
    year: string;
    layout: "feature" | "side" | "half" | "third";
    desc: string;
    status: string;
    statusKey: "live" | "building" | "archived";
    metrics: { v: string; l: string }[];
    tags: string[];
    vis: Vis;
};

const projects: Project[] = [
    {
        id: "P-01",
        title: "Glid",
        year: "2026–",
        layout: "feature",
        desc: "Founder & sole engineer of a published iOS/Android sports coordination app. Native SwiftUI frontend with a Rust/Axum & SurrealDB backend on GKE.",
        status: "Live (Beta)",
        statusKey: "building",
        metrics: [
            { v: "300+", l: "DAU" },
            { v: "99.4%", l: "uptime" },
            { v: "Rust", l: "backend" },
        ],
        tags: ["CONSUMER", "RUST", "SWIFTUI", "POSTGRES", "K8S"],
        vis: "glid",
    },
    {
        id: "P-02",
        title: "Autonomous Blimp · 152–0",
        year: "2023–24",
        layout: "side",
        desc: "Led software for a championship-winning robotics team. Quantized YOLOv5 for edge deployment and designed decentralized acoustic tracking systems.",
        status: "Shipped",
        statusKey: "live",
        metrics: [
            { v: "152–0", l: "record" },
            { v: "150g", l: "weight" },
            { v: "ONNX", l: "quant" },
        ],
        tags: ["ROBOTICS", "RUST", "ROS2", "RESEARCH", "ML"],
        vis: "blimp",
    },
    {
        id: "P-03",
        title: "Raytheon Drone Comp",
        year: "2024",
        layout: "half",
        desc: "1st Place winner. Designed autonomous flight paths using MAVLink and ArUco marker detection for precision payload deployment on moving targets.",
        status: "1st Place",
        statusKey: "live",
        metrics: [
            { v: "1st", l: "place" },
            { v: "MAVLink", l: "core" },
        ],
        tags: ["ROBOTICS", "PYTHON", "AUTONOMOUS"],
        vis: "motor",
    },
    {
        id: "P-04",
        title: "Freedom CTF",
        year: "2020–21",
        layout: "half",
        desc: "Built a custom cybersecurity platform from scratch. Hosted international competitions for 200+ teams, handling 50K+ concurrent requests.",
        status: "Archived",
        statusKey: "archived",
        metrics: [
            { v: "200+", l: "teams" },
            { v: "50k", l: "req/s" },
        ],
        tags: ["SECURITY", "GO", "INFRA", "FLASK"],
        vis: "ctf",
    },
    {
        id: "P-05",
        title: "Pipelined MIPS",
        year: "2023",
        layout: "third",
        desc: "VHDL implementation of a 5-stage pipelined MIPS processor with hazard detection, forwarding logic, and custom peripherals.",
        status: "Shipped",
        statusKey: "live",
        metrics: [
            { v: "VHDL", l: "core" },
            { v: "5-stage", l: "" },
        ],
        tags: ["EMBEDDED", "VHDL", "ARCH"],
        vis: "fpga",
    },
    {
        id: "P-06",
        title: "Multi-Agent Systems",
        year: "2025–",
        layout: "third",
        desc: "PhD Research at CIAO Lab. Modeling 12-state nonlinear blimp dynamics and implementing look-ahead pitch controllers in Rust.",
        status: "In progress",
        statusKey: "building",
        metrics: [
            { v: "PhD", l: "Year 2" },
            { v: "Rust", l: "Control" },
        ],
        tags: ["RESEARCH", "ROBOTICS", "RUST"],
        vis: "blimp",
    },
];

const filters = [
    "ALL",
    "ROBOTICS",
    "EMBEDDED",
    "CONSUMER",
    "SECURITY",
    "RESEARCH",
] as const;
---

<BaseLayout
    title="Projects"
    description="Selected work across robotics, embedded, consumer, and research."
>
    <div class="page">
        <header class="page-intro">
            <div>
                <div class="breadcrumb">~/projects (ls -l --sort=date)</div>
                <h1>Projects.</h1>
                <p class="lede">
                    Selected work across robotics, embedded, consumer, and
                    research. The list is opinionated — only systems I built
                    end-to-end.
                </p>
            </div>
            <div class="summary">
                <div><b>14</b> repositories tracked</div>
                <div><b>3</b> shipped in 2026</div>
                <div><b>1</b> in active beta</div>
            </div>
        </header>

        <div class="filter-row" id="filter-row">
            {
                filters.map((f) => (
                    <button
                        class={"filter-chip" + (f === "ALL" ? " on" : "")}
                        data-filter={f}
                    >
                        {f}
                    </button>
                ))
            }
            <span class="filter-meta" id="filter-count">
                {projects.length} matching //
            </span>
        </div>

        <div class="proj-grid" id="proj-grid">
            {
                projects.map((p) => (
                    <article
                        class={"proj " + p.layout + " fade-in"}
                        data-tags={p.tags.join(",")}
                    >
                        <span class="open">OPEN →</span>
                        <div class="pheader">
                            <div>
                                <div class="pid">
                                    {p.id} // {p.year}
                                </div>
                                <h3 class="ptitle">{p.title}</h3>
                            </div>
                            <div
                                class="pmeta"
                                style="flex-direction: column; align-items: flex-end; gap: 4px;"
                            >
                                <div
                                    style="display: flex; gap: 6px; align-items: center;"
                                >
                                    <span class={"dot " + p.statusKey} />
                                    <span style="text-transform: uppercase;">
                                        {p.status}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="pvis">
                            {p.vis === "glid" && (
                                <svg viewBox="0 0 240 100">
                                    <rect
                                        x="20"
                                        y="20"
                                        width="56"
                                        height="60"
                                        rx="8"
                                    />
                                    <rect
                                        x="92"
                                        y="20"
                                        width="56"
                                        height="60"
                                        rx="8"
                                    />
                                    <rect
                                        x="164"
                                        y="20"
                                        width="56"
                                        height="60"
                                        rx="8"
                                    />
                                    <line x1="48" y1="38" x2="64" y2="38" />
                                    <line x1="48" y1="50" x2="58" y2="50" />
                                    <line x1="120" y1="38" x2="136" y2="38" />
                                    <line x1="120" y1="50" x2="130" y2="50" />
                                    <line x1="192" y1="38" x2="208" y2="38" />
                                    <line x1="192" y1="50" x2="202" y2="50" />
                                    <circle
                                        cx="48"
                                        cy="68"
                                        r="3"
                                        class="dot"
                                    />
                                    <circle
                                        cx="120"
                                        cy="68"
                                        r="3"
                                        class="dot"
                                    />
                                    <circle
                                        cx="192"
                                        cy="68"
                                        r="3"
                                        class="dot"
                                    />
                                </svg>
                            )}
                            {p.vis === "blimp" && (
                                <svg viewBox="0 0 240 100">
                                    <ellipse cx="120" cy="50" rx="80" ry="22" />
                                    <line
                                        x1="40"
                                        y1="50"
                                        x2="200"
                                        y2="50"
                                        class="muted"
                                        stroke-dasharray="2 4"
                                    />
                                    <rect
                                        x="105"
                                        y="68"
                                        width="30"
                                        height="10"
                                        rx="2"
                                    />
                                    <line
                                        x1="120"
                                        y1="78"
                                        x2="120"
                                        y2="92"
                                    />
                                    <circle
                                        cx="120"
                                        cy="92"
                                        r="2"
                                        class="dot"
                                    />
                                    <path
                                        d="M30 30 Q60 20 90 30 Q120 40 150 30 Q180 20 210 30"
                                        class="muted"
                                    />
                                    <text
                                        x="178"
                                        y="20"
                                        font-family="JetBrains Mono"
                                        font-size="9"
                                        fill="var(--accent)"
                                        stroke="none"
                                    >
                                        EKF.lock
                                    </text>
                                </svg>
                            )}
                            {p.vis === "ctf" && (
                                <svg viewBox="0 0 240 100">
                                    <path d="M20 80 L60 80 L60 30 L80 30" />
                                    <path d="M80 30 L100 30 L100 60 L140 60 L140 20 L180 20 L180 70 L220 70" />
                                    <circle
                                        cx="60"
                                        cy="30"
                                        r="3"
                                        class="dot"
                                    />
                                    <circle
                                        cx="100"
                                        cy="60"
                                        r="3"
                                        class="dot"
                                    />
                                    <circle
                                        cx="140"
                                        cy="20"
                                        r="3"
                                        class="dot"
                                    />
                                    <circle
                                        cx="180"
                                        cy="70"
                                        r="3"
                                        class="dot"
                                    />
                                    <text
                                        x="20"
                                        y="22"
                                        font-family="JetBrains Mono"
                                        font-size="9"
                                        fill="var(--accent)"
                                        stroke="none"
                                    >
                                        flag&#123;root_me&#125;
                                    </text>
                                </svg>
                            )}
                            {p.vis === "motor" && (
                                <svg viewBox="0 0 240 100">
                                    <path
                                        class="muted"
                                        stroke-dasharray="3 3"
                                        d="M20 80 L220 80"
                                    />
                                    <path d="M20 80 C 60 80, 80 30, 220 25" />
                                    <path
                                        class="fill"
                                        d="M20 80 C 60 80, 80 30, 220 25 L220 80 Z"
                                    />
                                    <text
                                        x="180"
                                        y="18"
                                        font-family="JetBrains Mono"
                                        font-size="9"
                                        fill="var(--accent)"
                                        stroke="none"
                                    >
                                        F_ss
                                    </text>
                                    <text
                                        x="20"
                                        y="22"
                                        font-family="JetBrains Mono"
                                        font-size="9"
                                        fill="var(--accent)"
                                        stroke="none"
                                    >
                                        τ=0.227
                                    </text>
                                </svg>
                            )}
                            {p.vis === "yt" && (
                                <svg viewBox="0 0 240 100">
                                    <rect
                                        x="20"
                                        y="20"
                                        width="200"
                                        height="60"
                                        rx="6"
                                    />
                                    <polygon
                                        points="110,40 110,60 130,50"
                                        class="dot"
                                    />
                                    <line x1="20" y1="76" x2="80" y2="76" />
                                    <line x1="80" y1="76" x2="80" y2="80" />
                                    <line
                                        x1="20"
                                        y1="80"
                                        x2="220"
                                        y2="80"
                                        class="muted"
                                        stroke-dasharray="2 3"
                                    />
                                </svg>
                            )}
                            {p.vis === "fpga" && (
                                <svg viewBox="0 0 240 100">
                                    <rect
                                        x="80"
                                        y="20"
                                        width="80"
                                        height="60"
                                        rx="4"
                                    />
                                    <line x1="60" y1="30" x2="80" y2="30" />
                                    <line x1="60" y1="45" x2="80" y2="45" />
                                    <line x1="60" y1="60" x2="80" y2="60" />
                                    <line x1="60" y1="75" x2="80" y2="75" />
                                    <line x1="160" y1="30" x2="180" y2="30" />
                                    <line x1="160" y1="45" x2="180" y2="45" />
                                    <line x1="160" y1="60" x2="180" y2="60" />
                                    <line x1="160" y1="75" x2="180" y2="75" />
                                    <text
                                        x="100"
                                        y="55"
                                        font-family="JetBrains Mono"
                                        font-size="11"
                                        fill="var(--accent)"
                                        stroke="none"
                                    >
                                        VHDL
                                    </text>
                                </svg>
                            )}
                        </div>

                        <p class="pdesc">{p.desc}</p>
                        <div class="pmeta">
                            {p.metrics.map((m) => (
                                <span>
                                    <span style="color: var(--accent)">
                                        {m.v}
                                    </span>{" "}
                                    {m.l}
                                </span>
                            ))}
                        </div>
                        <div class="ptags">
                            {p.tags.map((t) => (
                                <span class="ptag">{t}</span>
                            ))}
                        </div>
                    </article>
                ))
            }
        </div>
    </div>

    <script is:inline>
        (function () {
            var row = document.getElementById("filter-row");
            var grid = document.getElementById("proj-grid");
            var count = document.getElementById("filter-count");
            if (!row || !grid || !count) return;
            var chips = row.querySelectorAll(".filter-chip");
            chips.forEach(function (c) {
                c.addEventListener("click", function () {
                    var f = c.getAttribute("data-filter");
                    chips.forEach((x) => x.classList.remove("on"));
                    c.classList.add("on");
                    var visible = 0;
                    grid.querySelectorAll(".proj").forEach(function (p) {
                        var tags = (p.getAttribute("data-tags") || "").split(
                            ",",
                        );
                        var show = f === "ALL" || tags.indexOf(f) !== -1;
                        p.style.display = show ? "" : "none";
                        if (show) visible++;
                    });
                    count.textContent = visible + " matching //";
                });
            });
        })();
    </script>
</BaseLayout>
