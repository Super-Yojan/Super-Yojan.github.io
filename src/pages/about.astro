---
import BaseLayout from "../layouts/BaseLayout.astro";

const stack = [
    "RUST",
    "C / C++",
    "ROS2",
    "SWIFTUI",
    "FPGA",
    "U-BOOT",
    "KUBERNETES",
    "GO",
    "PYTHON",
    "LINUX",
    "PCB DESIGN",
];
const marquee = [...stack, ...stack];
---

<BaseLayout title="About" description="About Yojan Gautam.">
    <div class="dashboard-container">
        <div class="bento-grid">
            <div
                class="bento-item hero span-2-col span-2-row fade-in delay-1"
            >
                <div class="bento-content">
                    <span class="kicker-label">/usr/bin/whoami</span>
                    <h2>Hello, I'm Yojan Gautam.</h2>
                    <p class="bio">
                        It started with breaking systems. At 17, I built a CTF
                        platform from scratch and hosted an international
                        competition with <b>500+ teams</b>. That obsession with
                        understanding how things fail shaped everything after.
                        In college, I moved to building — low-level embedded
                        work at Databuoy (U-Boot, FPGA, gunshot detection),
                        then robotics. My autonomous blimp software won a
                        competition <b>152–0</b>. I led a team in the Raytheon
                        Drone Competition, designed and sold a complete blimp
                        kit to 20 middle schoolers, and ran a competition for
                        them. Now I'm a <b>PhD researcher</b> at GMU's CIAO Lab
                        working on multi-agent autonomous systems, while
                        building <b>Glid</b> as a solo founder.
                    </p>
                    <div class="status-badge">
                        <span class="sb-pulse"></span> SYSTEM STATUS: BUILDING
                    </div>
                </div>
            </div>

            <div class="bento-item avatar span-2-col fade-in delay-2">
                <div class="cyber-face">IMG_01.RAW</div>
                <div class="scanline"></div>
            </div>

            <div class="bento-item lab fade-in delay-3">
                <span class="kicker-label">LAB FOCUS</span>
                <h3>CIAO Lab / Multi-Agent</h3>
            </div>

            <div class="bento-item music fade-in delay-3">
                <span class="kicker-label">FOUNDER</span>
                <div class="waveform">
                    <div class="wf-bar b1"></div>
                    <div class="wf-bar b2"></div>
                    <div class="wf-bar b3"></div>
                    <div class="wf-bar b4"></div>
                </div>
                <span class="mono-foot">Glid — Beta (DMV)</span>
            </div>

            <div class="bento-item stack span-4-col fade-in delay-4">
                <div class="marquee-wrapper">
                    <div class="marquee-content">
                        {marquee.map((s) => <span>{s} //</span>)}
                    </div>
                </div>
            </div>

            <div class="bento-item connect span-2-col fade-in delay-5">
                <a
                    href="https://github.com/Super-Yojan"
                    target="_blank"
                    class="social-link">GITHUB</a
                >
                <span class="sep">/</span>
                <a
                    href="https://linkedin.com/in/yojangautam"
                    target="_blank"
                    class="social-link">LINKEDIN</a
                >
                <span class="sep">/</span>
                <a
                    href="https://youtube.com/@Super-Yojan"
                    target="_blank"
                    class="social-link">YOUTUBE</a
                >
            </div>

            <div class="bento-item task span-2-col fade-in delay-5">
                <span class="tk-prompt">&gt;</span>
                <span class="tk-cmd">make build --release</span>
                <span class="tk-cursor">_</span>
            </div>
        </div>
    </div>
</BaseLayout>
